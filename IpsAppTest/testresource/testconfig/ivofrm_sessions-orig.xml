<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEANS//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
<beans>
	<bean id="serverSession"
		class="com.oocl.frm.transaction.toplink.loader.java.JavaSessionFactoryBean">
		<property name="sessionName" value="ServerSession" />
		<property name="sessionType" value="server" />
		<property name="jdbcConnectionStr"
			value="jdbc:oracle:thin:@shasudv7:1521:ivodb" />
		<property name="projectClassName"
			value="com.oocl.ivo.domain.mapping.IVOProject" />
		<property name="jdbcPrincipal" value="ivo_aeuser" />
		<property name="jdbcCredential" value="ivoaeuser" />
		<property name="jdbcDriverName"
			value="oracle.jdbc.driver.OracleDriver" />
		<property name="cpConfig">
			<bean
				class="com.oocl.frm.transaction.toplink.loader.java.ConnectionPoolBean">
				<property name="minRead" value="10" />
				<property name="maxRead" value="10" />
				<property name="minWrite" value="10" />
				<property name="maxWrite" value="10" />
			</bean>
		</property>
		<property name="cacheConfig">
			<bean class="com.oocl.frm.transaction.toplink.loader.java.CacheCoordinationBean">
				<property name="useCacheCoordination" value="false" />
				<property name="jndiURI" value="" />
				<property name="jndiPrincipal" value="" />
				<property name="jndiCredential" value="" />
				<property name="contextFactory" value="com.evermind.server.rmi.RMIInitialContextFactory" />
				<property name="topicName" value="" />
				<property name="topicConnectionFactoryName" value="" />
				<property name="topicHostURI" value="" />
				
			</bean>
		</property>
	</bean>
	<bean id="odsSession"
		class="com.oocl.frm.transaction.toplink.loader.java.JavaSessionFactoryBean">
		<property name="sessionName" value="ODSSession" />
		<property name="sessionType" value="server" />
		<property name="jdbcConnectionStr" value="jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=hklxd74v)(PORT=1521))(ADDRESS=(PROTOCOL=TCP)(HOST=hklxd75v)(PORT=1521))(LOAD_BALANCE=yes)(CONNECT_DATA=(SERVER=DEDICATED)(SERVICE_NAME=irnps4_1.oocl)))" />
		<property name="projectClassName"
			value="com.oocl.ivo.domain.mapping.ODSProject" />
		<property name="jdbcPrincipal" value="ips_appln" />
		<property name="jdbcCredential" value="ips_appln" />
		<property name="jdbcDriverName" value="oracle.jdbc.driver.OracleDriver" />
		<property name="cpConfig">
			<bean
				class="com.oocl.frm.transaction.toplink.loader.java.ConnectionPoolBean">
				<property name="minRead" value="5" />
				<property name="maxRead" value="5" />
				<property name="minWrite" value="5" />
				<property name="maxWrite" value="5" />
			</bean>
		</property>
	</bean>
	<bean id="sapSession"
		class="com.oocl.frm.transaction.toplink.loader.java.JavaSessionFactoryBean">
		<property name="sessionName" value="SapSession" />
		<property name="sessionType" value="database" />
		<property name="jdbcConnectionStr" value="jdbc:oracle:thin:@shasudv7:1521:ivodb" />
		<property name="projectClassName"
			value="com.oocl.ivo.domain.mapping.SAPProject" />
		<property name="jdbcPrincipal" value="ivo_aeuser" />
		<property name="jdbcCredential" value="ivoaeuser" />
		<property name="jdbcDriverName"
			value="oracle.jdbc.driver.OracleDriver" />
	</bean>
	<bean id="sessionMap"
		class="com.oocl.frm.transaction.toplink.loader.java.SessionMap">
		<property name="sessions">
			<map>
				<entry key="ServerSession" value-ref="serverSession" />
				<entry key="SapSession" value-ref="sapSession" />
				<entry key="ODSSession" value-ref="odsSession" />
			</map>
		</property>
	</bean>
</beans>
