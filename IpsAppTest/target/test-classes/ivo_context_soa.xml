<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:util="http://www.springframework.org/schema/util"
	xsi:schemaLocation="
       http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.5.xsd
       http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util-2.5.xsd">
        <!-- Note: Some code in this file are also reused in other MCCI/MOC functions-->
	<!-- SOA Section Start -->
	<!-- Resources -->
	<bean id="jmsConFactory" class="org.springframework.jndi.JndiObjectFactoryBean">
		<property name="jndiName" value="MessageFrameworkCF"></property>
		<!-- property name="jndiName" value="OracleASjms/MyCF"></property-->
	</bean>

	<bean id="soaMocJms" class="org.springframework.jms.core.JmsTemplate">
		<property name="messageConverter">
			<bean class="com.oocl.ivo.webservice.service.soa.SOAMOCMessageConverter" />
		</property>
		<property name="defaultDestination">
			<bean class="org.springframework.jndi.JndiObjectFactoryBean">
				<property name="jndiName"
					value="Topics/IPS.CS2.SHIPMENT_FOLDER.DOC_EVENT.TPC"></property>
				<!-- property name="jndiName" value="OracleASjms/MyQueue1" /-->
			</bean>
		</property>
		<property name="connectionFactory" ref="jmsConFactory" />
	</bean>
	
	<bean id="arorMocJms" class="org.springframework.jms.core.JmsTemplate">
		<property name="messageConverter">
			<bean class="com.oocl.ivo.webservice.service.moc.MOCMessageConverter" />
		</property>
		<property name="defaultDestination">
			<bean class="org.springframework.jndi.JndiObjectFactoryBean">
				<property name="jndiName"
					value="Topics/IPS.OLP.SHIPMENT_FOLDER.INV_DOC_EVENT.TPC"></property>
				<!-- property name="jndiName" value="OracleASjms/MyQueue1" /-->
			</bean>
		</property>
		<property name="connectionFactory" ref="jmsConFactory" />
	</bean>
	
	<!-- Email Support -->

	<!-- Services -->
	<bean id="soaInterfaceService"
		class="com.oocl.ivo.webservice.service.soa.SOAInterfaceServiceImpl">
		<property name="dmService" ref="mcciDmService" />
		<property name="smService" ref="soaMocService" />
		<property name="soaService" ref="soaService" />
		<property name="sender">
			<bean class="com.oocl.ivo.frm.webservice.common.MailBean" />
		</property>
	</bean>

	<bean id="soaMocService" class="com.oocl.ivo.webservice.service.soa.SOAMOCServiceImpl">
		<property name="jmsTemplate" ref="soaMocJms" />
		<property name="actionlogService" ref="soaService" />
	</bean>
	
	
	<bean id="dmmocInterfaceService"
		class="com.oocl.ivo.webservice.service.mccimoc.DMMOCInterfaceServiceImpl">
		<property name="dmService" ref="mcciDmService" />
		<property name="mocService" ref="mocService" />
		<property name="sender">
			<bean class="com.oocl.ivo.frm.webservice.common.MailBean" />
		</property>
	</bean>

	<bean id="mocService" class="com.oocl.ivo.webservice.service.moc.MOCServiceImpl">
		<property name="jmsTemplate" ref="arorMocJms" />
	</bean>

	<bean id="soaService" class="com.oocl.ivo.webservice.service.soa.SOAServiceImpl" />

	<bean id="mcciDmService" class="com.oocl.ivo.webservice.service.mcci.DMServiceImpl" />


	<!-- Processes -->
	<bean id="soaSendProcess"
		class="com.oocl.ivo.webservice.process.soa.SendSOADoc2MOCProcess">
		<property name="interfaceService" ref="soaInterfaceService" />
	</bean>

	<bean id="soaCancelProcess"
		class="com.oocl.ivo.webservice.process.soa.CancelSOADocInMOCProcess">
		<property name="interfaceService" ref="soaInterfaceService" />
	</bean>

	<!-- Message Listener -->
	<bean id="soaMessageListener"
		class="org.springframework.jms.listener.DefaultMessageListenerContainer">
		<property name="connectionFactory" ref="jmsConFactory" />
		<property name="destination">
			<bean class="org.springframework.jndi.JndiObjectFactoryBean">
				<property name="jndiName"
					value="Queues/CS2.IPS.SHIPMENT_FOLDER.SOA_DOC_EVENT_ACK.QUE" />
				<!-- property name="jndiName" value="OracleASjms/MyTopic1" /-->
			</bean>
		</property>
		<property name="messageListener" ref="soaInterfaceService" />
	</bean>
	
	<bean id="arorMessageListener"
		class="org.springframework.jms.listener.DefaultMessageListenerContainer">
		<property name="connectionFactory" ref="jmsConFactory" />
		<property name="destination">
			<bean class="org.springframework.jndi.JndiObjectFactoryBean">
				<property name="jndiName"
					value="Queues/OLP.IPS.SHIPMENT_FOLDER.INV_DOC_EVENT_ACK.QUE" />
				<!-- property name="jndiName" value="OracleASjms/MyTopic1" /-->
			</bean>
		</property>
		<property name="messageListener" ref="dmmocInterfaceService" />
	</bean>

	<!-- SOA Section End -->

	<!-- Process Dispatch Section -->
	<bean id="processMediator"
		class="com.oocl.ivo.frm.domain.access.process.mediator.ProcessMediator$ProcessMediatorFactory">
		<property name="dispatchList">
			<util:map map-class="java.util.HashMap">
				<entry key="com.oocl.ivo.webservice.process.soa.FinalizeSOADocsProcess">
					<util:list list-class="java.util.ArrayList">
						<ref bean="soaSendProcess" />
					</util:list>
				</entry>
				<entry key="com.oocl.ivo.webservice.process.soa.CancelSOADocsProcess">
					<util:list list-class="java.util.ArrayList">
						<ref bean="soaCancelProcess" />
					</util:list>
				</entry>
			</util:map>
		</property>
	</bean>
	<!-- Process Dispatch Section End -->


</beans>
