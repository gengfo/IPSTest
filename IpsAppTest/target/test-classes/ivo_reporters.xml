<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEANS//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
<beans>
<!-- Resources -->
	<bean id="mailres" class="com.oocl.frm.component.resource.javamail.MailResource">
		<property name="config">
			<bean class="com.oocl.frm.component.resource.javamail.MailConfigBean">
				<property name="transport">
					<bean class="com.oocl.frm.component.resource.common.ServerDescBean">
						<constructor-arg><value>smtp://smtpapp1:25/</value></constructor-arg>
					</bean>
				</property>
			</bean>
		</property>
	</bean>
	<!-- Reporters -->

	<bean id="jobCost" class="com.oocl.ivo.domain.entity.report.JobCostReporter" singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ReporterBridge">
				<property name="formatter">
					<bean class="com.oocl.frm.data.formatter.excel.PackedXLSFormatter">
						<constructor-arg>
							<null />
						</constructor-arg>
						<constructor-arg>
							<list>
								<value><![CDATA[$name_$date{yyyy-MM-dd HH_mm}_]]></value>
							</list>
						</constructor-arg>
						<constructor-arg>
							<value><![CDATA[$name_$date{yyyy-MM-dd HH_mm}]]></value>
						</constructor-arg>
						<constructor-arg>
							<value>20000</value>
						</constructor-arg>
						<property name="contentProvider">
							<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
						</property>
					</bean>
				</property>
			</bean>
		</property>
		<property name="distributor">
			<bean
				class="com.oocl.ivo.domain.facade.impl.report.distributor.ReportHistoryDistributor">
				<property name="next">
					<bean class="com.oocl.frm.util.report.direct.distributor.EmailDistributor">
						<property name="resource" ref="mailres"/>
						<property name="template" ref="jcTemplate" />
						<property name="exceptionTemplate" ref="exceptionTemplate" />
						<property name="maxSize" value="2097152" />
					</bean>
				</property>
			</bean>
		</property>
		<property name="timeout" value="1800"/>
	</bean>
	<bean id="jobCost.instant" class="com.oocl.ivo.domain.entity.report.JobCostReporter" singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ArrayFormatter">
				<property name="extractor">
					<bean
						class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
				</property>
				<property name="rowLimit" value="20000"/>
			</bean>
		</property>
		<property name="distributor">
			<bean class="com.oocl.ivo.webservice.process.report.DownloadRowDistributor" />
		</property>
		<property name="timeout" value="300"/>
	</bean>
	<bean id="arpMatch" class="com.oocl.ivo.domain.entity.report.ARPMatchReporter2" singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ReporterBridge">
				<property name="formatter">
					<bean class="com.oocl.frm.data.formatter.excel.PackedXLSFormatter">
						<constructor-arg>
							<null />
						</constructor-arg>
						<constructor-arg>
							<list>
								<value><![CDATA[$name_$date{yyyy-MM-dd HH_mm}_]]></value>
							</list>
						</constructor-arg>
						<constructor-arg>
							<value><![CDATA[$name_$date{yyyy-MM-dd HH_mm}]]></value>
						</constructor-arg>
						<constructor-arg>
							<value>20000</value>
						</constructor-arg>
						<property name="contentProvider">
							<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
						</property>
					</bean>
				</property>
			</bean>
		</property>
		<property name="distributor">
			<bean
				class="com.oocl.ivo.domain.facade.impl.report.distributor.ReportHistoryDistributor">
				<property name="next">
					<bean class="com.oocl.frm.util.report.direct.distributor.EmailDistributor">
						<property name="resource" ref="mailres"/>
						<property name="template" ref="arpTemplate" />
						<property name="exceptionTemplate" ref="exceptionTemplate" />
						<property name="maxSize" value="2097152" />
					</bean>
				</property>
			</bean>
		</property>
		<property name="timeout" value="1800"/>
	</bean>
	<bean id="arpMatch.instant" class="com.oocl.ivo.domain.entity.report.ARPMatchReporter2" singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ArrayFormatter">
				<property name="extractor">
					<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
				</property>
				<property name="rowLimit" value="20000"/>
			</bean>
		</property>
		<property name="distributor">
			<bean class="com.oocl.ivo.webservice.process.report.DownloadRowDistributor" />
		</property>
		<property name="timeout" value="300"/>
	</bean>
	<bean id="charge.instant" class="com.oocl.ivo.domain.entity.report.ChargeReporter" singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ArrayFormatter">
				<property name="extractor">
					<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
				</property>		
				<property name="rowLimit" value="20000"/>
			</bean>
		</property>
		<property name="distributor">
			<bean class="com.oocl.ivo.webservice.process.report.DownloadRowDistributor" />
		</property>
		<property name="timeout" value="300"/>
	</bean>
	<bean id="soa"
		class="com.oocl.ivo.webservice.service.soa.schedule.SOAReporter"
		singleton="false">
		<property name="mailResource" ref="mailres"/>
	</bean>		
	<bean id="linerInvMatch.instant" class="com.oocl.ivo.domain.entity.report.LinerInvMatchReporter"
		singleton="false">
		<property name="formatter" ref="instantLimDistributor" />
		<property name="distributor" ref="instantLimDistributor" />
		<property name="timeout" value="300"/>
	</bean>
	<bean id="linerTaxInvoice"
		class="com.oocl.ivo.domain.entity.report.LinerTaxInvoiceReporter"
		singleton="false">
		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ReporterBridge">
				<property name="formatter">
					<bean class="com.oocl.frm.data.formatter.excel.PackedXLSFormatter">
						<constructor-arg>
							<null />
						</constructor-arg>
						<constructor-arg>
							<list>
								<value>Report Result</value>
							</list>
						</constructor-arg>
						<constructor-arg>
							<value><![CDATA[Liner Tax Invoice Report.zip]]></value>
						</constructor-arg>
						<constructor-arg>
							<value>30000</value>
						</constructor-arg>
						<property name="contentProvider">
							<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
						</property>
					</bean>
				</property>
			</bean>
		</property>
		<property name="distributor">
			<bean class="com.oocl.frm.util.report.direct.distributor.EmailDistributor">
				<property name="resource" ref="mailres" />
				<property name="template">
					<bean
						class="com.oocl.ivo.domain.entity.report.linerti.mail.LTIResultMailTemplate" />
				</property>
				<property name="exceptionTemplate">
					<bean class="com.oocl.ivo.domain.entity.report.linerti.mail.LTIErrorMailTemplate"/>
				</property>
			</bean>
		</property>
	</bean>
	<bean id="vietnamTaxInvoice"
		class="com.oocl.ivo.domain.entity.report.VietnamTaxInvoiceReporter">

		<property name="formatter">
			<bean class="com.oocl.frm.util.report.direct.formatter.ReporterBridge">
				<property name="formatter">
					<bean class="com.oocl.frm.data.formatter.excel.XLSFormatter2">
						<constructor-arg>
							<null />
						</constructor-arg>
						<constructor-arg>
							<list>
								<value>Detail</value>
								<value>Summary</value>
							</list>
						</constructor-arg>
						<constructor-arg>
							<value><![CDATA[$name]]></value>
						</constructor-arg>
						<property name="contentProvider">
							<bean class="com.oocl.frm.tlquery.TopLinkTableContentProvider" />
						</property>
						<property name="rowLimit">
							<value>20000</value>
						</property>
						<property name="useStyle">
							<value>true</value>
						</property>
					</bean>
				</property>
			</bean>
		</property>
		<property name="distributor">
			<bean class="com.oocl.frm.util.report.direct.distributor.EmailDistributor">
				<property name="resource" ref="mailres" />
				<property name="template">
					<bean
						class="com.oocl.ivo.domain.entity.report.vietnamti.mail.VTIResultMailTemplate" />
				</property>
				<property name="exceptionTemplate">
					<bean
						class="com.oocl.ivo.domain.entity.report.vietnamti.mail.VTIErrorMailTemplate" />
				</property>
				<property name="maxSize" value="2097152" />
			</bean>
		</property>
	</bean>

    <bean id="VietnamTaxInvNumUsg"
        class="com.oocl.ivo.domain.entity.report.VietnamTaxInvNumUsgReporter"
        singleton="false">
        <property name="distributor">
            <bean
                class="com.oocl.frm.util.report.direct.distributor.EmailDistributor">
                <property name="resource" ref="mailres" />
                <property name="template">
                    <bean class="com.oocl.ivo.domain.entity.report.vietnamti.mail.VTINumMgtResultMailTemplate"/>
                </property>
                <property name="exceptionTemplate">
                    <bean class="com.oocl.ivo.domain.entity.report.vietnamti.mail.VTINumMgtErrorMailTemplate"/>
                </property>
                <property name="maxSize" value="2097152" />
            </bean>
        </property>
    </bean>

	<!-- Distributors -->
	<bean id="historyDistributor"
		class="com.oocl.ivo.domain.facade.impl.report.distributor.ReportHistoryDistributor" />
	<bean id="instantLimDistributor" singleton="false"
		class="com.oocl.ivo.webservice.process.report.InstantLinerInvMatchReportDistributor" />

	<!-- Email Templates -->
	<bean id="emptyTemplate" class="com.oocl.frm.util.report.direct.distributor.MailTemplate">
		<property name="subject" value=" " />
		<property name="content" value=" " />
	</bean>
	<bean id="jcTemplate"
		class="com.oocl.ivo.domain.facade.impl.report.distributor.ParamMailTemplate">
		<property name="subjectPattern" value="{0}" />
		<property name="contentPattern">
			<value><![CDATA[<html><body><p>Dear User,</p>
<p>&nbsp;&nbsp;Job Cost Report for Domestic Business : {0} is ready for your review.</p>
<p>Invoice & Payment System</p></body></html>]]></value>
		</property>
	</bean>
	<bean id="exceptionTemplate"
		class="com.oocl.ivo.domain.facade.impl.report.distributor.ParamMailTemplate">
		<property name="subjectPattern" value="{0} Fail to be Sent by Email" />
		<property name="contentPattern">
			<value><![CDATA[<html><body><p>Dear User,</p>
<p>&nbsp;&nbsp;The ARAP Matching Report for Domestic Business/Job Cost Report: {0} has been generated. It was failed to sent out the report by email due to the file exceeds the message size. Please login Invoice & Payment System to view or download the report.
</p><p>Invoice & Payment System</p></body></html>]]></value>
		</property>
	</bean>
	<bean id="arpTemplate"
		class="com.oocl.ivo.domain.facade.impl.report.distributor.ParamMailTemplate">
		<property name="subjectPattern" value="{0}" />
		<property name="contentPattern">
			<value><![CDATA[<html><body><p>Dear User,</p>
<p>&nbsp;&nbsp;ARAP Matching Report for Domestic Business : {0} is ready for your review.</p>
<p>Invoice & Payment System</p></body></html>]]></value>
		</property>
	</bean>
	<bean id="ltiTemplate"
		class="com.oocl.ivo.domain.facade.impl.report.distributor.ParamMailTemplate">
		<property name="subjectPattern" value="Liner Tax Invoice Report" />
		<property name="contentPattern">
			<value><![CDATA[Dear user,<br>	
We have attached the report for your reference.
<br>
<br>
Invoice & Payment System
		]]></value>
		</property>
	</bean>
	
</beans>
